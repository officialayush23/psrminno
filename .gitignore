# Unified ignore rules for root workspace

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Virtual environments
.venv/
venv/
backend/psrm/
**/.venv/
**/venv/
**/__pycache__/

# Environment files
.env
.env.*
backend/.env
frontend/.env
**/.env
**/.env.*

# GCP / Cloud credentials — NEVER commit these
gcs-service-account.json
**/gcs-service-account.json
*-service-account.json
*-credentials.json
service-account-*.json
service_account_key_*.json
**/service_account_key_*.json
storage_bucket.json
**/storage_bucket.json
serviceAccountKey.json
**/serviceAccountKey.json
certs.json
**/certs.json

# Node / frontend
node_modules/
frontend/node_modules/
frontend/dist/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Editor / OS
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Runtime data and uploads
backend/data/uploads/
backend/data/complaints/
backend/data/embeddings/
backend/data/tmp/

# Build and temporary files
*.log
*.tmp
*.temp

